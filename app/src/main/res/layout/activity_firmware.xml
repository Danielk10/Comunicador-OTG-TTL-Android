<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Encabezado ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧  Firmware PIC16F628A"
                android:textColor="#58A6FF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="PICMEM v3  ·  INTRC 4 MHz  ·  UART 9600 baud\nCompilador: SDCC"
                android:textColor="#8B949E"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ── Comando de compilación ─────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#0C2040"
            app:cardCornerRadius="10dp"
            app:strokeColor="#1F6FEB"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comando de compilación"
                    android:textColor="#58A6FF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#161B22"
                    android:padding="10dp"
                    android:text="sdcc --std-c99 -mpic14 -p16f628a\n     --use-non-free pic_firmware_v3.c"
                    android:textColor="#39D353"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="También disponible la app C PIC Compiler en Play Store\npara compilar directamente desde Android."
                    android:textColor="#CDD9E5"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Descargar archivos ──────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💾  Guardar archivos en Descargas/rom/"
                    android:textColor="#58A6FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="📄  Guardar código fuente  (.c)"
                    android:textAllCaps="false"
                    app:backgroundTint="#1F6FEB"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadHex"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙  Guardar firmware compilado  (.hex)"
                    android:textAllCaps="false"
                    app:backgroundTint="#238636"
                    app:cornerRadius="8dp" />

                <TextView
                    android:id="@+id/tvDownloadStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text=""
                    android:textColor="#3FB950"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Repositorio GitHub ─────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⬡  Repositorio GitHub"
                    android:textColor="#58A6FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Código fuente completo de la app Android, firmware PIC,\ndocumentación del protocolo y esquemas de hardware."
                    android:textColor="#CDD9E5"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenGithub"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Abrir en GitHub"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Chips soportados ───────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋  Chips soportados"
                    android:textColor="#58A6FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I2C EEPROM:   24C01 … 24C512  (128 B – 64 KB)\nSPI EEPROM:   25LC010A … 25LC1024  (128 B – 128 KB)\nFlash NOR SPI: W25Q08 … W25Q128  (1 MB – 16 MB)\nFlash NOR SPI: MX25L80 … MX25L128  (1 MB – 16 MB)"
                    android:textColor="#CDD9E5"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
