<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Encabezado de la app ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="24dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="App icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="OTG Flash EEPROM"
                android:textColor="#E6EDF3"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Versión 1.0.1"
                android:textColor="#8B949E"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Programador universal de memorias EEPROM I2C y Flash SPI\nmediante un PIC16F628A como puente USB-Serial."
                android:textColor="#CDD9E5"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ── Divider ──────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#30363D"
            android:layout_marginBottom="16dp" />

        <!-- ── Licencia ─────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄  Licencia"
                    android:textColor="#58A6FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apache License 2.0"
                    android:textColor="#CDD9E5"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvLicenseLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="https://www.apache.org/licenses/LICENSE-2.0"
                    android:textColor="#58A6FF"
                    android:textSize="12sp"
                    android:autoLink="web" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Código fuente / repositorio ──────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗  Repositorio oficial (GitHub)"
                    android:textColor="#58A6FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvRepoLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="github.com/Danielk10/Comunicador-OTG-TTL-Android"
                    android:textColor="#58A6FF"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenRepo"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Abrir en navegador"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Bibliotecas usadas ─────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦  Bibliotecas y dependencias"
                    android:textColor="#58A6FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- usb-serial-for-android -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="usb-serial-for-android  v3.10.0"
                    android:textColor="#E6EDF3"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Autor: mik3y   ·   Licencia: LGPL-2.1"
                    android:textColor="#8B949E"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tvLibUsbLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="github.com/mik3y/usb-serial-for-android"
                    android:textColor="#58A6FF"
                    android:textSize="11sp" />

                <!-- Material Components -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Material Components for Android"
                    android:textColor="#E6EDF3"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Autor: Google   ·   Licencia: Apache 2.0"
                    android:textColor="#8B949E"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tvLibMaterialLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="github.com/material-components/material-components-android"
                    android:textColor="#58A6FF"
                    android:textSize="11sp" />

                <!-- SDCC -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SDCC — Small Device C Compiler"
                    android:textColor="#E6EDF3"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Licencia: GPL   ·   Usado para compilar el firmware PIC"
                    android:textColor="#8B949E"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tvLibSdccLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="sdcc.sourceforge.net"
                    android:textColor="#58A6FF"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Desarrollador ─────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤  Desarrollador"
                    android:textColor="#58A6FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daniel Diamon"
                    android:textColor="#E6EDF3"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDevEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="✉  danielpdiamon@gmail.com"
                    android:textColor="#58A6FF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDevGithub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="⬡  github.com/Danielk10"
                    android:textColor="#58A6FF"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Política de privacidad ─────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrivacy"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="🔒  Política de Privacidad"
            app:cornerRadius="10dp" />

    </LinearLayout>
</ScrollView>
